generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  splitBills SplitBill[]
  wishlists Wishlist[]
  transactions Transaction[]
}

model Transaction {
  id        Int             @id @default(autoincrement())
  userId    Int
  type      TransactionType
  amount    Int
  category  String?
  note      String?
  receiptImage String?
  receiptImageName String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitBills SplitBill[]

  @@index([userId, createdAt])
  @@index([userId, type])
}

model Wishlist {
  id            Int      @id @default(autoincrement())
  userId        Int
  item          String
  price         Int
  priorityScore Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priorityScore, createdAt])
}

model SplitBill {
  id              Int                      @id @default(autoincrement())
  userId          Int
  title           String
  description     String?
  totalAmount     Int
  divisionMethod  SplitBillDivisionMethod  @default(CUSTOM)
  status          SplitBillStatus          @default(UNPAID)
  transactionId   Int?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  members         SplitBillMember[]
  items           SplitBillItem[]
  transaction     Transaction?             @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([transactionId])
}

model SplitBillMember {
  id          Int                   @id @default(autoincrement())
  splitBillId Int
  friendName  String
  amount      Int
  status      SplitBillMemberStatus @default(UNPAID)
  paidAt      DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  splitBill   SplitBill             @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  itemAssignments SplitBillItemAssignment[]

  @@index([splitBillId, status])
}

model SplitBillItem {
  id          Int       @id @default(autoincrement())
  splitBillId Int
  itemName    String
  price       Int
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  splitBill   SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  assignedTo  SplitBillItemAssignment[]

  @@index([splitBillId])
}

model SplitBillItemAssignment {
  id       Int              @id @default(autoincrement())
  itemId   Int
  memberId Int
  item     SplitBillItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  member   SplitBillMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([itemId, memberId])
  @@index([memberId])
}

enum SplitBillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SplitBillMemberStatus {
  UNPAID
  PAID
}

enum SplitBillDivisionMethod {
  EQUAL
  CUSTOM
}

enum TransactionType {
  INCOME
  EXPENSE
  SHARED_EXPENSE
}

