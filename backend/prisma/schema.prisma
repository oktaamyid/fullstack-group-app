generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  splitBills SplitBill[]
  wishlists Wishlist[]
  transactions Transaction[]
}

model Transaction {
  id        Int             @id @default(autoincrement())
  userId    Int
  type      TransactionType
  amount    Int
  category  String?
  note      String?
  receiptImage String?
  receiptImageName String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model Wishlist {
  id            Int      @id @default(autoincrement())
  userId        Int
  item          String
  price         Int
  priorityScore Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priorityScore, createdAt])
}

model SplitBill {
  id          Int               @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  totalAmount Int
  status      SplitBillStatus   @default(UNPAID)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     SplitBillMember[]

  @@index([userId, createdAt])
}

model SplitBillMember {
  id          Int                   @id @default(autoincrement())
  splitBillId Int
  friendName  String
  amount      Int
  status      SplitBillMemberStatus @default(UNPAID)
  paidAt      DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  splitBill   SplitBill             @relation(fields: [splitBillId], references: [id], onDelete: Cascade)

  @@index([splitBillId, status])
}

enum SplitBillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SplitBillMemberStatus {
  UNPAID
  PAID
}

enum TransactionType {
  INCOME
  EXPENSE
}

